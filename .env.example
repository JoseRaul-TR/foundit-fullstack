# foundit-fullstack/.env.example
# Copy this file to .env and fill in the values
# This file is shared by all apps in the monorepo

# Database
DATABASE_URL="postgresql://foundit:foundit_dev@localhost:5432/foundit_db?schema=public"

# ─── Backend (apps/api) ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the frontend app — used for CORS configuration
FRONTEND_URL=http://localhost:3000

# ─── HTTPS (apps/api, local development only) ─────────────────────────────────
# Off by default — the API runs over plain HTTP on localhost, which is fine
# for most local development.
#
# Turn this on only when you need to test something that behaves
# differently over a real TLS connection: Secure cookies (Better Auth won't
# set them over plain HTTP once useSecureCookies is true) or the Google
# OAuth callback flow, which Google restricts on non-localhost HTTPS origins.
#
# Setup (one-time):
#   1. brew install mkcert && mkcert -install
#   2. mkdir -p apps/api/certs && cd apps/api/certs
#   3. mkcert localhost 127.0.0.1 ::1
#      (generates localhost+2.pem and localhost+2-key.pem — add
#      apps/api/certs/ to .gitignore, never commit these)
#   4. Set USE_HTTPS=true and point the two paths below at those files
#   5. Update FRONTEND_URL/BETTER_AUTH_URL below to https:// and restart
#      both apps/api and apps/web (the Nuxt dev server needs its own HTTPS
#      config too — see nuxt.config.ts devServer.https once that's set up)
#
# Production (Railway): ALWAYS leave USE_HTTPS=false here. Railway
# terminates TLS at its own edge and forwards plain HTTP to the container
# (see the `trust proxy` setting in index.ts) — the Node process binding
# raw HTTPS itself in that environment would be redundant, not more secure,
# and Railway's proxy isn't set up to forward encrypted traffic to you
# undecrypted. Set it in your Railway environment variables, don't rely on
# the default staying false in a shared/inherited config.
USE_HTTPS=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# ─── Auth — Better Auth ───────────────────────────────────────────────────────
# Minimum 32 characters — used to sign session tokens
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_here_minimum_32_characters
# Base URL of THIS backend (used to build absolute callback/redirect URLs)
# — scheme + host + port only, no path. Switch to https:// if USE_HTTPS=true
# locally, or to your Railway HTTPS domain in production.
BETTER_AUTH_URL=http://localhost:3001

# ─── TMDB API ─────────────────────────────────────────────────────────────────
# Get your API read access token at: https://www.themoviedb.org/settings/api
# Use the "API Read Access Token" (Bearer token), not the API Key (v3 auth)
TMDB_API_KEY=your_tmdb_read_access_token_here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (note the /v1 — auth is now versioned along with
# the rest of the API, see basePath in lib/auth.ts):
#   Local:      http://localhost:3001/api/v1/auth/callback/google
#   Production: https://<your-railway-domain>/api/v1/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=