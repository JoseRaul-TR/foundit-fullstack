# foundit-fullstack/apps/web/.env.example
# Copy this file to apps/web/.env
# Nuxt-specific environment variables

# ─── API ──────────────────────────────────────────────────────────────────────
# URL of the Express backend
# NUXT_PUBLIC_ prefix makes this available in both server and client
NUXT_PUBLIC_API_BASE=http://localhost:3001

# ─── App ──────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_NAME=FoundIt