{
  "name": "foundit-api",
  "version": "1.0.0",
  "description": "Backend API for FoundIt",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "pnpm db:test:migrate && vitest run",
    "test:watch": "pnpm db:test:migrate && vitest",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:test:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "db:generate": "pnpm exec prisma generate",
    "db:studio": "pnpm exec prisma studio",
    "db:push": "pnpm exec prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "node",
    "express",
    "prisma",
    "tmdb"
  ],
  "author": "José Raúl Tenza Ramírez",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@foundit/types": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
