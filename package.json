{
  "name": "foundit-fullstack",
  "version": "0.0.1",
  "description": "Full-stack web app to discover where to watch movies and TV shows across streaming services worldwide. Built with Nuxt 4, Vue 3, Express, PostgreSQL and Better Auth.",
  "private": true,
  "main": "",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "keywords": [
    "monorepo",
    "fullstack",
    "nuxt",
    "vue",
    "express",
    "prisma",
    "tmdb"
  ],
  "author": "José Raúl Tenza Ramírez",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
